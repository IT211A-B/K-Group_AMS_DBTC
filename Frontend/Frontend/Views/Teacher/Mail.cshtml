@{
    Layout = "_Layout";
    ViewData["Title"] = "Mail";
    var userName = Context.Session.GetString("UserName") ?? "Teacher";
    var userId = Context.Session.GetString("UserId") ?? "";
}
<div class="page-header">
    <div>
        <h4><i class="bi bi-envelope"></i> Mail</h4>
        <ol class="breadcrumb"><li class="breadcrumb-item active">Mail</li></ol>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <div class="card-header-title"><i class="bi bi-send"></i> Compose Message</div>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">To <span class="text-danger">*</span></label>
                    <select class="form-select" id="toMode">
                        <option value="all">All Users</option>
                        <option value="teacher">All Teachers</option>
                        <option value="student">All Students</option>
                        <option value="specific">Specific Person…</option>
                    </select>
                    <div id="specificRecipBox" style="display:none;margin-top:8px;">
                        <input type="text" class="form-control form-control-sm" id="recipientSearch" placeholder="Type name or email…" autocomplete="off">
                        <div id="recipientDropdown" style="position:absolute;z-index:9999;background:#fff;border:1px solid #e2e8f0;border-radius:6px;width:calc(100% - 32px);max-height:200px;overflow-y:auto;display:none;"></div>
                        <div id="selectedRecipient" class="mt-2" style="font-size:12px;color:#16A34A;"></div>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">Type</label>
                    <select class="form-select" id="msgType">
                        <option value="message">General Message</option>
                        <option value="excuse">Excuse Letter</option>
                        <option value="concern">Concern / Report</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Subject <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="msgSubject" placeholder="e.g. Request for leave">
                </div>
                <div class="mb-3">
                    <label class="form-label">Message <span class="text-danger">*</span></label>
                    <textarea class="form-control" id="msgBody" rows="5" placeholder="Write your message here…"></textarea>
                </div>
                <button class="btn btn-primary w-100" id="sendMsgBtn"><i class="bi bi-send"></i> Send Message</button>
            </div>
        </div>
    </div>
    <div class="col-md-8">
        <div class="card">
            <div class="card-header flex-wrap gap-2">
                <div class="card-header-title"><i class="bi bi-inbox"></i> Inbox &amp; Notifications</div>
                <div class="d-flex gap-2 ms-auto">
                    <select class="form-select form-select-sm" id="filterMailType" style="width:130px;">
                        <option value="">All</option>
                        <option value="unread">Unread</option>
                        <option value="read">Read</option>
                    </select>
                    <button class="btn btn-sm btn-outline-secondary" id="markAllReadBtn"><i class="bi bi-check2-all"></i> Mark all read</button>
                    <button class="btn btn-sm btn-outline-danger" id="clearAllMailBtn"><i class="bi bi-trash3"></i> Clear</button>
                </div>
            </div>
            <div id="mailList" style="min-height:300px;"></div>
        </div>
    </div>
</div>

<div class="modal fade" id="viewMsgModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-envelope-open"></i> <span id="vmTitle"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2" style="font-size:13px;color:#64748b;">
                    <strong>From:</strong> <span id="vmFrom"></span> &nbsp;|&nbsp;
                    <strong>Type:</strong> <span id="vmType"></span> &nbsp;|&nbsp;
                    <strong>Date:</strong> <span id="vmDate"></span>
                </div>
                <hr>
                <div id="vmBody" style="white-space:pre-wrap;font-size:14px;"></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var allMails=[], selectedUserId='', selectedUserName='';

        $('#toMode').on('change',function(){
            var v=$(this).val();
            $('#specificRecipBox').toggle(v==='specific');
            if(v!=='specific'){ selectedUserId=''; selectedUserName=''; $('#selectedRecipient').text(''); $('#recipientSearch').val(''); }
        });

        var searchTimer;
        $('#recipientSearch').on('input',function(){
            clearTimeout(searchTimer);
            var q=$(this).val().trim();
            selectedUserId=''; selectedUserName=''; $('#selectedRecipient').text('');
            if(q.length<2){ $('#recipientDropdown').hide(); return; }
            searchTimer=setTimeout(function(){
                $.ajax({ url:'/api/proxy/api/UserSearch?q='+encodeURIComponent(q), dataType:'json',
                    success:function(users){
                        if(!users.length){ $('#recipientDropdown').html('<div class="p-2 text-muted" style="font-size:12px;">No users found</div>').show(); return; }
                        var html='';
                        users.forEach(function(u){
                            var gid=parseInt(u.groupId)||0;
                            var role=gid===2?'Teacher':gid===3?'Student':'Admin';
                            html+='<div class="recip-item p-2 border-bottom" data-uid="'+u.userId+'" data-name="'+u.name+'" style="cursor:pointer;font-size:13px;"><strong>'+u.name+'</strong> <span class="text-muted">('+role+')</span><br><small>'+u.email+'</small></div>';
                        });
                        $('#recipientDropdown').html(html).show();
                    }
                });
            },300);
        });

        $(document).on('click','.recip-item',function(){
            selectedUserId=$(this).data('uid');
            selectedUserName=$(this).data('name');
            $('#recipientSearch').val(selectedUserName);
            $('#selectedRecipient').text('✓ Sending to: '+selectedUserName);
            $('#recipientDropdown').hide();
        });

        $(document).on('click',function(e){
            if(!$(e.target).closest('#recipientSearch,#recipientDropdown').length) $('#recipientDropdown').hide();
        });

        function renderMails(data){
            var filter=$('#filterMailType').val();
            var list=data.filter(function(m){ if(filter==='unread') return !m.isRead; if(filter==='read') return m.isRead; return true; });
            if(!list.length){ $('#mailList').html('<div class="text-center text-muted py-5"><i class="bi bi-inbox" style="font-size:2.5rem;display:block;opacity:.3;"></i><div class="mt-2">No messages</div></div>'); return; }
            var html='';
            list.forEach(function(m){
                var unread=!m.isRead;
                var typeIcon=m.type==='excuse'?'<i class="bi bi-file-earmark-text text-warning"></i>':m.type==='concern'?'<i class="bi bi-exclamation-triangle text-danger"></i>':'<i class="bi bi-envelope text-primary"></i>';
                var dt=m.createdAt?new Date(m.createdAt).toLocaleString():'';
                html+='<div class="mail-item d-flex align-items-start gap-3 p-3 border-bottom'+(unread?' mail-unread':'')+'" data-id="'+m.id+'" style="cursor:pointer;'+(unread?'background:#F0F7FF;':'')+'">'
                    +'<div style="font-size:20px;margin-top:2px;">'+typeIcon+'</div>'
                    +'<div style="flex:1;min-width:0;">'
                    +'<div class="d-flex justify-content-between"><strong style="font-size:13px;">'+(m.title||'(No subject)')+'</strong><span style="font-size:11px;color:#94A3B8;">'+dt+'</span></div>'
                    +'<div style="font-size:12px;color:#64748B;">From: '+(m.senderName||'Unknown')+' ('+(m.senderRole||'')+')</div>'
                    +'<div style="font-size:12px;color:#94A3B8;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">'+(m.message||'')+'</div>'
                    +'</div>'
                    +(unread?'<span class="badge bg-primary" style="font-size:10px;">New</span>':'')
                    +'</div>';
            });
            $('#mailList').html(html);
        }

        function loadMail(){
            $.ajax({ url:'/api/Notifications', dataType:'json',
                success:function(data){ allMails=Array.isArray(data)?data:[]; renderMails(allMails); },
                error:function(){ showToast('Failed to load mail.','error'); }
            });
        }

        $(function(){
            loadMail();

            $('#sendMsgBtn').on('click',function(){
                var mode=$('#toMode').val();
                var subject=$('#msgSubject').val().trim();
                var body=$('#msgBody').val().trim();
                var recipId=mode;
                if(!subject){ showToast('Subject is required.','warning'); return; }
                if(!body){ showToast('Message is required.','warning'); return; }
                if(mode==='specific'){
                    if(!selectedUserId){ showToast('Please select a recipient.','warning'); return; }
                    recipId=selectedUserId;
                }
                $('#page-loader').fadeIn(150);
                $.ajax({ type:'POST', url:'/api/Notifications', contentType:'application/json',
                    data:JSON.stringify({recipientId:recipId,title:subject,message:body,type:$('#msgType').val()}),
                    success:function(){
                        $('#page-loader').fadeOut(200);
                        showToast('Message sent.','success');
                        $('#msgSubject,#msgBody').val('');
                        selectedUserId=''; selectedUserName=''; $('#selectedRecipient').text(''); $('#recipientSearch').val('');
                        $('#toMode').val('all'); $('#specificRecipBox').hide();
                        loadMail();
                        if(typeof loadNotifications==='function') loadNotifications();
                    },
                    error:function(x){ $('#page-loader').fadeOut(200); showToast('Send failed: '+(x.responseJSON&&x.responseJSON.message||x.statusText),'error'); }
                });
            });

            $('#clearAllMailBtn').on('click',function(){
                $.ajax({ type:'DELETE', url:'/api/Notifications', success:function(){ loadMail(); if(typeof loadNotifications==='function') loadNotifications(); showToast('Mail cleared.','success'); } });
            });

            $(document).on('click','.mail-item',function(){
                var id=$(this).data('id');
                var m=allMails.find(function(x){ return x.id==id; });
                if(!m) return;
                $('#vmTitle').text(m.title||'(No subject)');
                $('#vmFrom').text((m.senderName||'Unknown')+' ('+(m.senderRole||'')+')');
                $('#vmType').text(m.type||'message');
                $('#vmDate').text(m.createdAt?new Date(m.createdAt).toLocaleString():'');
                $('#vmBody').text(m.message||'');
                $('#viewMsgModal').modal('show');
                if(!m.isRead) $.ajax({ type:'PUT', url:'/api/Notifications/'+id+'/read', success:function(){ loadMail(); } });
            });

            $('#filterMailType').on('change',function(){ renderMails(allMails); });
            $('#markAllReadBtn').on('click',function(){
                var unread=allMails.filter(function(m){ return !m.isRead; });
                if(!unread.length){ showToast('No unread messages.','info'); return; }
                var defs=unread.map(function(m){ return $.ajax({ type:'PUT', url:'/api/Notifications/'+m.id+'/read' }); });
                $.when.apply($,defs).done(function(){ loadMail(); showToast('All marked as read.','success'); });
            });
        });
    </script>
}