@{
    ViewData["Title"] = "Manage Teachers";
}
<div class="page-header">
    <div>
        <h4><i class="bi bi-person-badge"></i> Teachers</h4>
        <ol class="breadcrumb"><li class="breadcrumb-item"><a href="/Admin/Dashboard">Home</a></li><li class="breadcrumb-item active">Teachers</li></ol>
    </div>
    <button class="btn btn-primary" id="openAddTeacher"><i class="bi bi-person-plus"></i> Add Teacher</button>
</div>
<div class="card">
    <div class="card-header">
        <div class="card-header-title"><i class="bi bi-table"></i> Teacher List</div>
        <div class="search-bar">
            <i class="bi bi-search"></i>
            <input type="text" class="form-control" id="searchTeacher" placeholder="Search...">
        </div>
    </div>
    <div class="table-wrapper">
        <table class="table table-striped">
            <thead><tr><th>#</th><th>Name</th><th>Email</th><th>Department</th><th>Gender</th><th>Phone</th><th>Actions</th></tr></thead>
            <tbody id="teacherTableBody"></tbody>
        </table>
    </div>
    <div class="pagination-wrapper"><div id="teacherPagination"></div></div>
</div>

<div class="modal fade" id="teacherModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="teacherModalTitle"><i class="bi bi-person-plus"></i> Add Teacher</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="teacherUserId">
                <input type="hidden" id="teacherRecordId">
                <input type="hidden" id="teacherUserGroupId">
                <h6 class="text-muted mb-3"><i class="bi bi-person-fill"></i> User Account</h6>
                <div class="row g-2">
                    <div class="col-md-6"><label class="form-label">Full Name <span class="text-danger">*</span></label><input type="text" class="form-control" id="teacherFullName"></div>
                    <div class="col-md-6"><label class="form-label">Email <span class="text-danger">*</span></label><input type="email" class="form-control" id="teacherEmail"></div>
                    <div class="mb-2" id="passwordField">
                        <label class="form-label">Password <span class="text-danger">*</span></label>
                        <input type="password" class="form-control" id="teacherPassword">
                    </div>
                    <div class="col-md-4"><label class="form-label">Phone</label><input type="text" class="form-control" id="teacherPhone"></div>
                    <div class="col-md-4">
                        <label class="form-label">Gender</label>
                        <select class="form-select" id="teacherGender">
                            <option value="M">Male</option>
                            <option value="F">Female</option>
                        </select>
                    </div>
                    <div class="col-md-4"><label class="form-label">Birth Date</label><input type="date" class="form-control" id="teacherBirthDate"></div>
                    <div class="col-md-12"><label class="form-label">Address</label><input type="text" class="form-control" id="teacherAddress"></div>
                </div>
                <hr>
                <h6 class="text-muted mb-3"><i class="bi bi-briefcase"></i> Teacher Info</h6>
                <div class="row g-2">
                    <div class="col-md-12">
                        <label class="form-label">Department <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="teacherDept" placeholder="e.g. College of Computing">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveTeacherBtn">Save Teacher</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var TEACHER_GROUP_ID = 2;
        var allTeachers = [];
        var teacherPaginator;

        function toUtcIso(dateVal) {
            if (!dateVal) return new Date().toISOString();
            return new Date(dateVal).toISOString();
        }

        function renderTeacherRow(t, idx) {
            var name   = t._fullName || '—';
            var email  = t._email   || '—';
            var dept   = t._dept    || '—';
            var gender = t._gender === 'M' ? 'Male' : t._gender === 'F' ? 'Female' : (t._gender || '—');
            var phone  = t._phone   || '—';
            var uid    = t._uid     || '';
            var tid    = t._tid     || '';

            return `<tr>
                <td>${idx+1}</td>
                <td><div class="d-flex align-items-center gap-2">
                    <div style="width:32px;height:32px;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:12px;">${(name[0]||'?').toUpperCase()}</div>
                    ${name}</div></td>
                <td>${email}</td>
                <td>${dept}</td>
                <td>${gender}</td>
                <td>${phone}</td>
                <td class="d-flex gap-1">
                    <button class="btn btn-sm btn-outline-primary edit-teacher" data-idx="${idx}">
                        <i class="bi bi-pencil"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-danger delete-teacher"
                        data-tid="${tid}" data-uid="${uid}" data-name="${name}">
                        <i class="bi bi-trash"></i>
                    </button>
                </td></tr>`;
        }

        function loadTeachers() {
            $('#page-loader').fadeIn(150);
            $.when(
                $.ajax({ url: '/api/Teacher', dataType: 'json' }),
                $.ajax({ url: '/api/User',    dataType: 'json' })
            ).done(function(tRes, uRes) {
                var teachers = Array.isArray(tRes[0]) ? tRes[0] : [];
                var users    = Array.isArray(uRes[0]) ? uRes[0] : [];

                var teacherUsers = users.filter(function(u) {
                    var gid = u.userGroup_ID ?? u.UserGroup_ID ?? u.userGroupId ?? 0;
                    return String(gid) === String(TEACHER_GROUP_ID);
                }).sort(function(a, b) {
                    return (a.user_ID || 0) - (b.user_ID || 0);
                });

                teachers.sort(function(a, b) {
                    return (a.teacher_ID || a.id || 0) - (b.teacher_ID || b.id || 0);
                });

                allTeachers = teacherUsers.map(function(u, i) {
                    var t   = teachers[i] || {};
                    var uid = u.user_ID  ?? u.userId  ?? null;
                    var tid = t.teacher_ID ?? t.id    ?? null;

                    return {
                        _uid:      uid,
                        _tid:      tid,
                        _ugid:     u.userGroup_ID ?? TEACHER_GROUP_ID,
                        _fullName: u.full_Name    ?? u.fullName    ?? '',
                        _email:    u.email        ?? '',
                        _phone:    u.phone_Number ?? u.phoneNumber ?? '',
                        _gender:   u.gender       ?? '',
                        _bdate:    u.birth_Date   ?? u.birthDate   ?? '',
                        _addr:     u.address      ?? '',
                        _dept:     t.department   ?? t.Department  ?? ''
                    };
                });

                $('#page-loader').fadeOut(200);

                if (teacherPaginator) teacherPaginator.refresh(allTeachers);
                else teacherPaginator = paginate({
                    data: allTeachers, pageSize: 10,
                    containerId: 'teacherTableBody', paginationId: 'teacherPagination',
                    renderRow: renderTeacherRow, emptyMsg: 'No teachers found.', colSpan: 7
                });
            }).fail(function() {
                $('#page-loader').fadeOut(200);
                showToast('Failed to load teachers.', 'error');
            });
        }

        $(function () {
            loadTeachers();

            $('#openAddTeacher').click(function () {
                $('#teacherModalTitle').html('<i class="bi bi-person-plus"></i> Add Teacher');
                $('#teacherUserId,#teacherRecordId,#teacherUserGroupId').val('');
                $('#teacherFullName,#teacherEmail,#teacherPassword,#teacherPhone,#teacherAddress,#teacherDept').val('');
                $('#teacherGender').val('M');
                $('#teacherBirthDate').val('');
                $('#passwordField').show();
                $('#teacherModal').modal('show');
            });

            $('#searchTeacher').on('keyup', function () {
                var q = $(this).val().toLowerCase();
                teacherPaginator.refresh(allTeachers.filter(function(t) {
                    return (t._fullName || '').toLowerCase().includes(q) ||
                           (t._email   || '').toLowerCase().includes(q) ||
                           (t._dept    || '').toLowerCase().includes(q);
                }));
            });

            $('#saveTeacherBtn').click(function () {
                var uid      = $('#teacherUserId').val();
                var tid      = $('#teacherRecordId').val();
                var ugid     = parseInt($('#teacherUserGroupId').val()) || TEACHER_GROUP_ID;
                var fullName = $('#teacherFullName').val().trim();
                var email    = $('#teacherEmail').val().trim();
                var dept     = $('#teacherDept').val().trim();

                if (!fullName) { showToast('Full name is required.', 'warning'); return; }
                if (!email)    { showToast('Email is required.', 'warning'); return; }
                if (!uid && !$('#teacherPassword').val().trim()) { showToast('Password is required.', 'warning'); return; }
                if (!dept)     { showToast('Department is required.', 'warning'); return; }

                var userData = {
                    full_Name:     fullName,
                    email:         email,
                    phone_Number:  $('#teacherPhone').val().trim(),
                    gender:        $('#teacherGender').val(),
                    birth_Date:    toUtcIso($('#teacherBirthDate').val()),
                    address:       $('#teacherAddress').val().trim(),
                    userGroup_ID:  TEACHER_GROUP_ID,
                    lastUpdatedBy: 'admin'
                };

                if (!uid) {
                    // Adding new teacher
                    userData.password = $('#teacherPassword').val().trim();
                } else {
                    // Editing — send unchanged marker
                    userData.user_ID      = parseInt(uid);
                    userData.userGroup_ID = ugid;
                    userData.password     = 'unchanged';
                }

                var teacherData = { department: dept, lastUpdatedBy: 'admin' };

                if (uid) {
                    updateTeacher(uid, userData, tid, teacherData, function() {
                        $('#teacherModal').modal('hide');
                        loadTeachers();
                    });
                } else {
                    addTeacher(userData, teacherData, function() {
                        $('#teacherModal').modal('hide');
                        loadTeachers();
                    });
                }
            });

            $(document).on('click', '.edit-teacher', function () {
                var idx = parseInt($(this).data('idx'));
                var m   = allTeachers[idx];
                if (!m) { showToast('Teacher data not found.', 'error'); return; }

                $('#teacherModalTitle').html('<i class="bi bi-pencil"></i> Edit Teacher');
                $('#teacherUserId').val(m._uid     || '');
                $('#teacherRecordId').val(m._tid   || '');
                $('#teacherUserGroupId').val(m._ugid || TEACHER_GROUP_ID);
                $('#teacherFullName').val(m._fullName || '');
                $('#teacherEmail').val(m._email    || '');
                $('#teacherPhone').val(m._phone    || '');
                $('#teacherGender').val(m._gender  || 'M');
                $('#teacherBirthDate').val((m._bdate || '').substring(0, 10));
                $('#teacherAddress').val(m._addr   || '');
                $('#teacherDept').val(m._dept      || '');
                $('#passwordField').hide();
                $('#teacherModal').modal('show');
            });

            $(document).on('click', '.delete-teacher', function () {
                var tid  = $(this).data('tid');
                var uid  = $(this).data('uid');
                var name = $(this).data('name');
                confirmDelete(name, function() { deleteTeacher(uid, tid, loadTeachers); });
            });
        });
    </script>
}