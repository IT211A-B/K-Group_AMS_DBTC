@{
    Layout = "_Layout";
    ViewData["Title"] = "Take Attendance";
}
<div class="page-header flex-wrap gap-2">
    <div>
        <h4><i class="bi bi-calendar-check"></i> Take Attendance</h4>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Teacher/Dashboard">Home</a></li>
            <li class="breadcrumb-item active">Attendance</li>
        </ol>
    </div>
    <div class="d-flex align-items-center gap-2 ms-auto flex-wrap">
        <button class="btn btn-success btn-sm" id="scanQrBtn" title="Scan QR Code">
            <i class="bi bi-qr-code-scan"></i> Scan QR
        </button>
    </div>
</div>

<!-- Today's Schedule Info Banner -->
<div id="scheduleInfoBanner" class="alert alert-info d-none mb-3" style="border-left:4px solid var(--accent);border-radius:8px;">
    <div class="d-flex align-items-center gap-3 flex-wrap">
        <div><i class="bi bi-clock-history me-1"></i> <strong>Today's Schedule:</strong></div>
        <div id="scheduleInfoText" class="text-muted" style="font-size:13px;">Loading...</div>
    </div>
</div>
<div id="noScheduleBanner" class="alert alert-warning d-none mb-3" style="border-left:4px solid #F59E0B;border-radius:8px;">
    <i class="bi bi-exclamation-triangle me-2"></i> <strong>No schedule assigned for today.</strong> Please contact your administrator if this is incorrect.
</div>

<div class="card mb-4">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Course</label>
                <select class="form-select form-select-sm" id="courseDropdown">
                    <option value="">Select Course…</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Schedule (today)</label>
                <select class="form-select form-select-sm" id="scheduleDropdown">
                    <option value="">Select Schedule…</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label">Student Email</label>
                <div class="input-group input-group-sm">
                    <input type="email" class="form-control" id="studentEmailInput" placeholder="student@dbtc-cebu">
                    <button class="btn btn-primary" type="button" id="markEmailBtn">Mark</button>
                </div>
            </div>
        </div>
        <p class="text-muted small mb-0 mt-2" id="sessionStatus">Select course and schedule, then scan QR or enter email.</p>
    </div>
</div>

<!-- QR Scan Modal -->
<div class="modal fade" id="qrScanModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-qr-code-scan"></i> Scan Student QR</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <p class="text-muted small mb-2">Point the camera at the student's QR code.</p>
                <div id="qrReader" style="width:100%;max-width:400px;margin:0 auto;"></div>
                <div id="qrScanError" class="alert alert-danger mt-2" style="display:none;"></div>
            </div>
        </div>
    </div>
</div>

<!-- Student Scan Result Popup -->
<div class="modal fade" id="scanResultModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered" style="max-width:340px;">
        <div class="modal-content" style="border-radius:16px;overflow:hidden;border:none;box-shadow:0 20px 60px rgba(0,0,0,0.18);">
            <div id="scanResultHeader" class="text-white text-center py-4 px-3" style="background:var(--accent);">
                <div id="scanResultIcon" style="font-size:44px;margin-bottom:6px;"></div>
                <div id="scanResultStatus" style="font-size:24px;font-weight:800;letter-spacing:2px;"></div>
            </div>
            <div class="p-4">
                <div class="text-center mb-3">
                    <div id="scanResultAvatar" style="width:64px;height:64px;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-size:24px;font-weight:700;margin:0 auto 10px;border:3px solid #E0E7FF;"></div>
                    <div id="scanResultName" style="font-size:17px;font-weight:700;color:#1E293B;"></div>
                    <div id="scanResultId" style="font-size:12px;color:#64748B;margin-top:3px;font-family:monospace;"></div>
                </div>
                <div class="d-flex justify-content-around text-center" style="background:#F8FAFF;border-radius:10px;padding:12px 8px;margin-bottom:16px;">
                    <div>
                        <div style="font-size:10px;color:#94A3B8;text-transform:uppercase;letter-spacing:.5px;">Time</div>
                        <div id="scanResultTime" style="font-size:15px;font-weight:700;color:#334155;margin-top:2px;"></div>
                    </div>
                    <div style="border-left:1px solid #E2E8F0;"></div>
                    <div>
                        <div style="font-size:10px;color:#94A3B8;text-transform:uppercase;letter-spacing:.5px;">Session #</div>
                        <div id="scanResultSession" style="font-size:15px;font-weight:700;color:#334155;margin-top:2px;"></div>
                    </div>
                </div>
                <button type="button" class="btn btn-primary w-100" id="scanResultContinue" style="border-radius:10px;font-weight:600;">
                    <i class="bi bi-qr-code-scan me-1"></i> Continue Scanning
                </button>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-4">
        <div class="stat-card">
            <div class="stat-icon green"><i class="bi bi-check-circle"></i></div>
            <div><div class="stat-label">Present</div><div class="stat-value" id="presentCount">0</div></div>
        </div>
    </div>
    <div class="col-4">
        <div class="stat-card">
            <div class="stat-icon red"><i class="bi bi-x-circle"></i></div>
            <div><div class="stat-label">Absent</div><div class="stat-value" id="absentCount">0</div></div>
        </div>
    </div>
    <div class="col-4">
        <div class="stat-card">
            <div class="stat-icon orange"><i class="bi bi-clock"></i></div>
            <div><div class="stat-label">Late</div><div class="stat-value" id="lateCount">0</div></div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header flex-wrap gap-2">
        <div class="card-header-title"><i class="bi bi-table"></i> Student Attendance</div>
        <div class="d-flex gap-2 ms-auto align-items-center">
            <select class="form-select form-select-sm" id="filterStatus" style="width:130px;">
                <option value="">All Status</option>
                <option value="Present">Present</option>
                <option value="Absent">Absent</option>
                <option value="Late">Late</option>
                <option value="unmarked">Unmarked</option>
            </select>
        </div>
    </div>
    <div class="table-wrapper">
        <table class="table table-striped">
            <thead><tr><th>#</th><th>Student ID</th><th>Student Name</th><th>Time Marked</th><th>Status</th></tr></thead>
            <tbody id="attendanceTableBody"></tbody>
        </table>
    </div>
    <div class="px-4 py-2 border-top d-flex gap-4" style="font-size:13px;background:#F8FAFF;">
        <span>Total: <strong id="sumTotal">0</strong></span>
        <span class="text-success">Present: <strong id="sumPresent">0</strong></span>
        <span class="text-danger">Absent: <strong id="sumAbsent">0</strong></span>
        <span class="text-warning">Late: <strong id="sumLate">0</strong></span>
        <span class="text-muted">Unmarked: <strong id="sumUnmarked">0</strong></span>
    </div>
    <div class="pagination-wrapper"><div id="attendancePagination"></div></div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html5-qrcode/2.3.8/html5-qrcode.min.js"></script>
    <script src="~/js/teacher-attendance.js" asp-append-version="true"></script>
}