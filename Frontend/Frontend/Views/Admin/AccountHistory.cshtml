@{
    Layout = "_Layout";
    ViewData["Title"] = "Account History";
}
<div class="page-header flex-wrap gap-2">
    <div>
        <h4><i class="bi bi-clock-history"></i> Account History</h4>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Admin/Dashboard">Home</a></li>
            <li class="breadcrumb-item active">Account History</li>
        </ol>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon blue"><i class="bi bi-people"></i></div><div><div class="stat-label">Students</div><div class="stat-value" id="histStudents">—</div></div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon green"><i class="bi bi-person-badge"></i></div><div><div class="stat-label">Teachers</div><div class="stat-value" id="histTeachers">—</div></div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon orange"><i class="bi bi-journal-bookmark-fill"></i></div><div><div class="stat-label">Courses</div><div class="stat-value" id="histCourses">—</div></div></div></div>
    <div class="col-md-3"><div class="stat-card"><div class="stat-icon red"><i class="bi bi-activity"></i></div><div><div class="stat-label">Activities</div><div class="stat-value" id="histActivities">—</div></div></div></div>
</div>

<div class="card">
    <div class="card-header flex-wrap gap-2">
        <div class="card-header-title"><i class="bi bi-list-ul"></i> Activity Log</div>
        <div class="d-flex flex-wrap gap-2 ms-auto">
            <select class="form-select form-select-sm" id="histTypeFilter" style="width:160px;">
                <option value="">All Types</option>
                <option value="AccountCreated">Account Creation</option>
                <option value="Login">Login</option>
                <option value="AttendanceScan">Attendance</option>
                <option value="MailSent">Mail</option>
                <option value="Notification">Notifications</option>
            </select>
        </div>
    </div>
    <div class="table-wrapper">
        <table class="table table-striped">
            <thead><tr><th>#</th><th>Type</th><th>Description</th><th>Actor</th><th>Date (UTC)</th></tr></thead>
            <tbody id="histTableBody"></tbody>
        </table>
    </div>
    <div class="pagination-wrapper"><div id="histPagination"></div></div>
</div>

@section Scripts {
    <script>
        var allActivities = [], histPg;

        function typeBadge(t) {
            var map = {
                AccountCreated: '<span class="badge bg-primary">Account</span>',
                Login: '<span class="badge bg-secondary">Login</span>',
                AttendanceScan: '<span class="badge bg-success">Attendance</span>',
                MailSent: '<span class="badge bg-info text-dark">Mail</span>',
                Notification: '<span class="badge bg-warning text-dark">Notification</span>'
            };
            return map[t] || '<span class="badge bg-light text-dark">' + (t || 'Other') + '</span>';
        }

        function renderHistRow(a, i) {
            var dt = a.createdAt ? new Date(a.createdAt).toLocaleString() : '—';
            return '<tr><td>' + (i + 1) + '</td><td>' + typeBadge(a.activity_Type || a.activityType) + '</td>'
                + '<td>' + (a.description || '—') + '</td>'
                + '<td>' + (a.actor_Name || a.actorName || '—') + '</td>'
                + '<td style="font-size:12px;">' + dt + '</td></tr>';
        }

        function applyFilter() {
            var type = $('#histTypeFilter').val();
            var list = type ? allActivities.filter(function (a) { return (a.activity_Type || a.activityType) === type; }) : allActivities;
            if (histPg) histPg.refresh(list);
            else histPg = paginate({ data: list, pageSize: 20, containerId: 'histTableBody', paginationId: 'histPagination', colSpan: 5, emptyMsg: 'No activity recorded yet.', renderRow: renderHistRow });
        }

        $(function () {
            $('#page-loader').fadeIn(150);
            $.when(
                $.ajax({ url: '/api/Dashboard/stats', dataType: 'json' }),
                $.ajax({ url: '/api/AccountHistory', dataType: 'json' })
            ).done(function (sR, hR) {
                var stats = sR[0] || {};
                $('#histStudents').text(stats.totalStudents ?? stats.TotalStudents ?? '—');
                $('#histTeachers').text(stats.totalTeachers ?? stats.TotalTeachers ?? '—');
                $('#histCourses').text(stats.totalCourses ?? stats.TotalCourses ?? '—');
                allActivities = Array.isArray(hR[0]) ? hR[0] : [];
                $('#histActivities').text(allActivities.length);
                applyFilter();
                $('#page-loader').fadeOut(200);
            }).fail(function () {
                $('#page-loader').fadeOut(200);
                showToast('Failed to load account history.', 'error');
            });
            $('#histTypeFilter').on('change', applyFilter);
        });
    </script>
}
