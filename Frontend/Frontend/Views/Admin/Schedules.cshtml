@{
    Layout = "_Layout";
    ViewData["Title"] = "Class Schedules";
}
<div class="page-header">
    <div>
        <h4><i class="bi bi-calendar-week"></i> Class Schedules</h4>
        <ol class="breadcrumb"><li class="breadcrumb-item"><a href="/Admin/Dashboard">Home</a></li><li class="breadcrumb-item active">Schedules</li></ol>
    </div>
    <button class="btn btn-primary" id="openAddSchedule"><i class="bi bi-plus-circle"></i> Add Schedule</button>
</div>

<div class="card">
    <div class="card-header flex-wrap gap-2">
        <div class="card-header-title"><i class="bi bi-list-ul"></i> Schedule List</div>
    </div>
    <div class="table-wrapper">
        <table class="table table-striped">
            <thead><tr><th>ID</th><th>Course</th><th>Section</th><th>Day</th><th>Start</th><th>End</th><th>Semester</th><th>Year</th><th>Actions</th></tr></thead>
            <tbody id="scheduleTableBody"></tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="scheduleModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-plus-circle"></i> Add Schedule</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="scheduleId">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Course <span class="text-danger">*</span></label>
                        <select class="form-select" id="schCourse"></select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Section <span class="text-danger">*</span></label>
                        <select class="form-select" id="schSection"></select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Day <span class="text-danger">*</span></label>
                        <select class="form-select" id="schDay">
                            <option value="Monday">Monday</option>
                            <option value="Tuesday">Tuesday</option>
                            <option value="Wednesday">Wednesday</option>
                            <option value="Thursday">Thursday</option>
                            <option value="Friday">Friday</option>
                            <option value="Saturday">Saturday</option>
                            <option value="Sunday">Sunday</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Start Time <span class="text-danger">*</span></label>
                        <input type="time" class="form-control" id="schStart">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">End Time <span class="text-danger">*</span></label>
                        <input type="time" class="form-control" id="schEnd">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Semester</label>
                        <input type="number" class="form-control" id="schSemester" value="1" min="1">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Academic Year</label>
                        <input type="text" class="form-control" id="schYear" value="2025-2026">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveScheduleBtn"><i class="bi bi-check-lg"></i> Save Schedule</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
var allSchedules = [], allCourses = [], allSections = [];
function safeArr(r) { return Array.isArray(r) ? r : (r && r.$values ? r.$values : []); }
function fmtTime(t) {
    if (!t) return '';
    if (t.length === 5) return t + ':00';
    return t;
}
function loadAll() {
    $('#page-loader').fadeIn(150);
    $.when(
        $.getJSON('/api/proxy/AttendanceManagement/Schedule'),
        $.getJSON('/api/proxy/AttendanceManagement/Course'),
        $.getJSON('/api/proxy/AttendanceManagement/Section')
    ).done(function (sR, cR, secR) {
        allSchedules = safeArr(sR[0]);
        allCourses = safeArr(cR[0]);
        allSections = safeArr(secR[0]);
        renderSchedules();
        fillSelects();
        $('#page-loader').fadeOut(200);
    }).fail(function () {
        $('#page-loader').fadeOut(200);
        showToast('Failed to load schedules.', 'error');
    });
}
function fillSelects() {
    var ch = '<option value="">Select course</option>';
    allCourses.forEach(function (c) {
        ch += '<option value="' + (c.course_ID || c.Course_ID) + '">' + (c.code || '') + ' - ' + (c.title || '') + '</option>';
    });
    $('#schCourse').html(ch);
    var sh = '<option value="">Select section</option>';
    allSections.forEach(function (s) {
        var sid = s.section_ID || s.Section_ID || s.id;
        sh += '<option value="' + sid + '">' + (s.section_Code || s.Section_Code || ('Section ' + sid)) + '</option>';
    });
    $('#schSection').html(sh);
}
function courseName(id) {
    var c = allCourses.find(function (x) { return String(x.course_ID || x.Course_ID) === String(id); });
    return c ? ((c.code || '') + ' - ' + (c.title || '')) : ('#' + id);
}
function sectionName(id) {
    var s = allSections.find(function (x) { return String(x.section_ID || x.Section_ID || x.id) === String(id); });
    return s ? (s.section_Code || s.Section_Code || ('#' + id)) : ('#' + id);
}
function renderSchedules() {
    var html = '';
    allSchedules.forEach(function (s) {
        var id = s.schedule_Id || s.schedule_ID || s.Schedule_Id;
        html += '<tr><td>' + id + '</td><td>' + courseName(s.course_ID || s.Course_ID) + '</td><td>' + sectionName(s.section_ID || s.Section_ID) +
            '</td><td>' + (s.dayOfWeek || s.DayOfWeek) + '</td><td>' + (s.startTime || s.StartTime) + '</td><td>' + (s.endTime || s.EndTime) +
            '</td><td>' + (s.semester || s.Semester) + '</td><td>' + (s.academicYear || s.AcademicYear) + '</td>' +
            '<td><button class="btn btn-sm btn-outline-danger del-sch" data-id="' + id + '"><i class="bi bi-trash"></i></button></td></tr>';
    });
    $('#scheduleTableBody').html(html || '<tr><td colspan="9" class="text-center text-muted py-4">No schedules yet.</td></tr>');
}
$(function () {
    loadAll();
    $('#openAddSchedule').on('click', function () {
        $('#scheduleId').val('');
        $('#schCourse, #schSection, #schStart, #schEnd').val('');
        $('#schDay').val('Monday');
        $('#schSemester').val('1');
        $('#schYear').val('2025-2026');
        $('#scheduleModal').modal('show');
    });
    $('#saveScheduleBtn').on('click', function () {
        var courseId = $('#schCourse').val();
        var sectionId = $('#schSection').val();
        var start = $('#schStart').val();
        var end = $('#schEnd').val();
        if (!courseId || !sectionId || !start || !end) {
            showToast('Course, section, start time, and end time are required.', 'warning');
            return;
        }
        var id = $('#scheduleId').val();
        var data = {
            course_ID: parseInt(courseId, 10),
            section_ID: parseInt(sectionId, 10),
            dayOfWeek: $('#schDay').val(),
            startTime: fmtTime(start),
            endTime: fmtTime(end),
            semester: parseInt($('#schSemester').val(), 10) || 1,
            academicYear: $('#schYear').val() || '2025-2026'
        };
        var req = id
            ? $.ajax({ type: 'PUT', url: '/api/proxy/AttendanceManagement/Schedule/' + id, contentType: 'application/json', data: JSON.stringify(data) })
            : $.ajax({ type: 'POST', url: '/api/proxy/AttendanceManagement/Schedule', contentType: 'application/json', data: JSON.stringify(data) });
        $('#page-loader').fadeIn(150);
        req.done(function () {
            $('#page-loader').fadeOut(200);
            showToast('Schedule saved.', 'success');
            $('#scheduleModal').modal('hide');
            loadAll();
        }).fail(function (x) {
            $('#page-loader').fadeOut(200);
            var msg = (x.responseJSON && x.responseJSON.message) || x.responseText || 'Save failed.';
            showToast(msg, 'error');
        });
    });
    $(document).on('click', '.del-sch', function () {
        var id = $(this).data('id');
        if (!confirm('Delete this schedule?')) return;
        $.ajax({ type: 'DELETE', url: '/api/proxy/AttendanceManagement/Schedule/' + id })
            .done(function () { showToast('Deleted.', 'success'); loadAll(); });
    });
});
</script>
}
