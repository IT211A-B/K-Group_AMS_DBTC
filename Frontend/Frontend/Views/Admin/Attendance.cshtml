@{
    Layout = "_Layout";
    ViewData["Title"] = "Attendance";
}
<div class="page-header flex-wrap gap-2">
    <div>
        <h4><i class="bi bi-calendar-check"></i> Attendance</h4>
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Admin/Dashboard">Home</a></li>
            <li class="breadcrumb-item active">Attendance</li>
        </ol>
    </div>
    <div class="d-flex gap-2 align-items-center flex-wrap ms-auto">
        <button class="btn btn-success btn-sm" id="adminScanQrBtn">
            <i class="bi bi-qr-code-scan"></i> Scan QR
        </button>
        <input type="date" id="attendanceDate" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" style="width:auto;">
    </div>
</div>

<div class="modal fade" id="adminQrScanModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-md">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-qr-code-scan"></i> Scan QR — Mark Attendance</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <div class="mb-2">
                    <select class="form-select form-select-sm" id="qrCourseSelect" style="max-width:300px;margin:0 auto;">
                        <option value="">Select Course…</option>
                    </select>
                </div>
                <div id="adminQrReader" style="max-width:350px;margin:0 auto;"></div>
                <div id="adminQrScanResult" class="mt-3" style="display:none;">
                    <div class="alert alert-success" id="adminQrResultMsg"></div>
                    <div class="d-flex gap-2 justify-content-center">
                        <button class="btn btn-success" id="adminMarkPresentBtn"><i class="bi bi-check-circle"></i> Present</button>
                        <button class="btn btn-warning" id="adminMarkLateBtn"><i class="bi bi-clock"></i> Late</button>
                        <button class="btn btn-danger" id="adminMarkAbsentBtn"><i class="bi bi-x-circle"></i> Absent</button>
                    </div>
                </div>
                <div id="adminQrScanError" class="alert alert-danger mt-2" style="display:none;"></div>
                <p class="text-muted small mt-2">Point camera at a student or teacher QR code.</p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon green"><i class="bi bi-check-circle"></i></div><div><div class="stat-label">Present</div><div class="stat-value" id="presentCount">0</div></div></div></div>
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon red"><i class="bi bi-x-circle"></i></div><div><div class="stat-label">Absent</div><div class="stat-value" id="absentCount">0</div></div></div></div>
    <div class="col-md-4"><div class="stat-card"><div class="stat-icon orange"><i class="bi bi-clock"></i></div><div><div class="stat-label">Late</div><div class="stat-value" id="lateCount">0</div></div></div></div>
</div>

<div class="card">
    <div class="card-header flex-wrap gap-2">
        <div class="card-header-title"><i class="bi bi-table"></i> Attendance Sheet</div>
        <div class="d-flex flex-wrap gap-2 ms-auto align-items-center">
            <select class="form-select form-select-sm" id="viewType" style="width:140px;">
                <option value="student">Students</option>
                <option value="teacher">Teachers</option>
            </select>
            <select class="form-select form-select-sm" id="filterCourse" style="width:180px;">
                <option value="">All Courses</option>
            </select>
            <select class="form-select form-select-sm" id="filterStatus" style="width:130px;">
                <option value="">All Status</option>
                <option value="Present">Present</option>
                <option value="Absent">Absent</option>
                <option value="Late">Late</option>
                <option value="unmarked">Unmarked</option>
            </select>
        </div>
    </div>
    <div class="table-wrapper">
        <table class="table table-striped">
            <thead><tr><th>#</th><th>Name</th><th>Type</th><th>Status</th><th>Action</th></tr></thead>
            <tbody id="attendanceTableBody"></tbody>
        </table>
    </div>
    <div class="px-4 py-2 border-top d-flex gap-4" style="font-size:13px;background:#F8FAFF;">
        <span>Total: <strong id="sumTotal">0</strong></span>
        <span class="text-success">Present: <strong id="sumPresent">0</strong></span>
        <span class="text-danger">Absent: <strong id="sumAbsent">0</strong></span>
        <span class="text-warning">Late: <strong id="sumLate">0</strong></span>
        <span class="text-muted">Unmarked: <strong id="sumUnmarked">0</strong></span>
    </div>
    <div class="pagination-wrapper"><div id="attendancePagination"></div></div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html5-qrcode/2.3.8/html5-qrcode.min.js"></script>
    <script src="~/js/Ajax/attendance.js"></script>
    <script>
        var attPag, allStudents=[], allTeachers=[], allUsers=[], allEnrollments=[], allAttRec=[], allCourses=[], displayData=[], currentDate='';
        var adminQrScanner = null, adminScannedData = null;

        function updateCounts() {
            var p=0, a=0, l=0, u=0;
            displayData.forEach(function(r){ var s=(r.status||'').toLowerCase(); if(s==='present')p++; else if(s==='absent')a++; else if(s==='late')l++; else u++; });
            $('#presentCount,#sumPresent').text(p);
            $('#absentCount,#sumAbsent').text(a);
            $('#lateCount,#sumLate').text(l);
            $('#sumUnmarked').text(u);
            $('#sumTotal').text(displayData.length);
        }

        function renderRow(r, idx) {
            var name=r._name, status=r.status||'', attId=r._attId||'', eid=r._eid||'';
            var cls=status.toLowerCase()==='present'?'badge-present':status.toLowerCase()==='absent'?'badge-absent':status.toLowerCase()==='late'?'badge-late':'';
            var badge=status?'<span class="badge '+cls+'">'+status+'</span>':'<span class="text-muted" style="font-size:12px;">Unmarked</span>';
            var type=r._type==='teacher'?'<span style="background:#EDE9FE;color:#6D28D9;font-size:11px;padding:2px 8px;border-radius:20px;font-weight:600;">Teacher</span>':'<span style="background:#DBEAFE;color:var(--accent);font-size:11px;padding:2px 8px;border-radius:20px;font-weight:600;">Student</span>';
            var init=(name[0]||'?').toUpperCase();
            return '<tr>'+
                '<td>'+(idx+1)+'</td>'+
                '<td><div class="d-flex align-items-center gap-2"><div style="width:32px;height:32px;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:12px;">'+init+'</div>'+name+'</div></td>'+
                '<td>'+type+'</td>'+
                '<td>'+badge+'</td>'+
                '<td><div class="d-flex gap-1">'+
                '<button class="btn btn-xs att-mark" style="background:#DCFCE7;color:#16A34A;border:none;padding:3px 8px;border-radius:5px;font-size:11px;" data-eid="'+eid+'" data-attid="'+attId+'" data-status="Present">P</button>'+
                '<button class="btn btn-xs att-mark" style="background:#FEE2E2;color:#DC2626;border:none;padding:3px 8px;border-radius:5px;font-size:11px;" data-eid="'+eid+'" data-attid="'+attId+'" data-status="Absent">A</button>'+
                '<button class="btn btn-xs att-mark" style="background:#FEF3C7;color:#D97706;border:none;padding:3px 8px;border-radius:5px;font-size:11px;" data-eid="'+eid+'" data-attid="'+attId+'" data-status="Late">L</button>'+
                '</div></td>'+
                '</tr>';
        }

        function loadAttendanceData() {
            currentDate = $('#attendanceDate').val();
            var viewType = $('#viewType').val();
            var courseFilter = $('#filterCourse').val();
            $('#page-loader').fadeIn(150);

            $.when(
                $.ajax({ url: '/api/Student', dataType: 'json' }),
                $.ajax({ url: '/api/Teacher', dataType: 'json' }),
                $.ajax({ url: '/api/User', dataType: 'json' }),
                $.ajax({ url: '/AttendanceManagement/Enrollment', dataType: 'json' }),
                $.ajax({ url: '/AttendanceManagement/Attendance', dataType: 'json' }),
                $.ajax({ url: '/AttendanceManagement/Course', dataType: 'json' })
            ).done(function(sR, tR, uR, eR, aR, cR) {
                allStudents = Array.isArray(sR[0]) ? sR[0] : [];
                allTeachers = Array.isArray(tR[0]) ? tR[0] : [];
                allUsers = Array.isArray(uR[0]) ? uR[0] : [];
                allEnrollments = Array.isArray(eR[0]) ? eR[0] : [];
                allAttRec = Array.isArray(aR[0]) ? aR[0] : [];
                allCourses = Array.isArray(cR[0]) ? cR[0] : [];

                var cHtml = '<option value="">All Courses</option>';
                allCourses.forEach(function(c){ cHtml += '<option value="'+(c.course_ID||c.id)+'">'+(c.code||'')+ ' — '+(c.title||'')+'</option>'; });
                $('#filterCourse, #qrCourseSelect').html(cHtml);

                if (viewType === 'student') {
                    var enrollments = courseFilter
                        ? allEnrollments.filter(function(e){ return String(e.course_ID)===String(courseFilter); })
                        : allEnrollments;

                    displayData = enrollments.map(function(e) {
                        var student = allStudents.find(function(s){ return String(s.student_ID||s.id)===String(e.student_ID); });
                        var user = student ? allUsers.find(function(u){ return String(u.user_ID)===String(student.user_ID); }) : null;
                        var att = allAttRec.find(function(a){ return String(a.enrollment_ID)===String(e.enrollment_ID) && (a.date||a.attendanceDate||'').substring(0,10)===currentDate; });
                        return {
                            _name: user ? (user.full_Name||user.email) : 'Student #'+e.student_ID,
                            _eid: e.enrollment_ID, _attId: att?(att.attendance_ID||att.id):'',
                            status: att ? att.status : '', _type: 'student'
                        };
                    });
                } else {
                    displayData = allTeachers.map(function(t) {
                        var user = allUsers.find(function(u){ return String(u.user_ID)===String(t.user_ID); });
                        return {
                            _name: user ? (user.full_Name||user.email) : 'Teacher #'+(t.teacher_ID||t.id),
                            _eid: '', _attId: '', status: '', _type: 'teacher'
                        };
                    });
                }

                applyFilter();
                $('#page-loader').fadeOut(200);
            }).fail(function(){ $('#page-loader').fadeOut(200); showToast('Failed to load data.','error'); });
        }

        function applyFilter() {
            var statusF = $('#filterStatus').val();
            var filtered = statusF
                ? displayData.filter(function(r){ if(statusF==='unmarked') return !r.status; return (r.status||'').toLowerCase()===statusF.toLowerCase(); })
                : displayData;
            if (attPag) attPag.refresh(filtered);
            else attPag = paginate({ data: filtered, pageSize: 20, containerId: 'attendanceTableBody', paginationId: 'attendancePagination', colSpan: 5, emptyMsg: 'No records.', renderRow: renderRow });
            updateCounts();
        }

        function startAdminQr() {
            $('#adminQrScanResult').hide(); $('#adminQrScanError').hide(); adminScannedData = null;
            if (!adminQrScanner) adminQrScanner = new Html5Qrcode("adminQrReader");
            adminQrScanner.start(
                { facingMode: "environment" },
                { fps: 10, qrbox: { width: 250, height: 250 } },
                function(text) {
                    adminQrScanner.stop().catch(function(){});
                    var userId = text.trim();
                    if (userId.startsWith('{')) { try { var o=JSON.parse(userId); userId=o.userId||o.user_ID||o.id||userId; } catch(e){} }
                    if (userId.startsWith('user:')) userId = userId.substring(5);

                    var courseId = $('#qrCourseSelect').val();
                    if (!courseId) { $('#adminQrScanError').text('Please select a course first.').show(); return; }

                    var student = allStudents.find(function(s){ return String(s.user_ID)===String(userId); });
                    if (!student) { $('#adminQrScanError').text('Student not found for scanned QR.').show(); return; }

                    var sid = student.student_ID || student.id;
                    var enrollment = allEnrollments.find(function(e){ return String(e.student_ID)===String(sid) && String(e.course_ID)===String(courseId); });
                    if (!enrollment) { $('#adminQrScanError').text('Student not enrolled in selected course.').show(); return; }

                    var user = allUsers.find(function(u){ return String(u.user_ID)===String(userId); });
                    var name = user ? (user.full_Name||user.email) : 'Student';
                    var att = allAttRec.find(function(a){ return String(a.enrollment_ID)===String(enrollment.enrollment_ID) && (a.date||a.attendanceDate||'').substring(0,10)===currentDate; });

                    adminScannedData = { eid: enrollment.enrollment_ID, attId: att?(att.attendance_ID||att.id):'', name: name };
                    $('#adminQrResultMsg').text('Scanned: '+name+(att?' — Current: '+att.status:' — Not yet marked'));
                    $('#adminQrScanResult').show();
                },
                function(){}
            ).catch(function(err){ $('#adminQrScanError').text('Camera error: '+err).show(); });
        }

        function adminMarkScanned(status) {
            if (!adminScannedData) return;
            var d = adminScannedData;
            var date = currentDate;
            var req = d.attId
                ? $.ajax({ type:'PUT', url:'/AttendanceManagement/Attendance/'+d.attId, contentType:'application/json', data:JSON.stringify({ attendance_ID: parseInt(d.attId), enrollment_ID: parseInt(d.eid), status: status, date: date+'T00:00:00Z', lastUpdatedBy: 'admin' }) })
                : $.ajax({ type:'POST', url:'/AttendanceManagement/Attendance', contentType:'application/json', data:JSON.stringify({ enrollment_ID: parseInt(d.eid), status: status, date: date+'T00:00:00Z', lastUpdatedBy: 'admin' }) });
            req.then(function(){ showToast(d.name+' marked as '+status,'success'); $('#adminQrScanResult').hide(); adminScannedData=null; loadAttendanceData(); setTimeout(startAdminQr,800); })
               .catch(function(){ showToast('Mark failed.','error'); });
        }

        $(function() {
            currentDate = $('#attendanceDate').val();
            loadAttendanceData();

            $('#attendanceDate').on('change', loadAttendanceData);
            $('#viewType, #filterCourse').on('change', loadAttendanceData);
            $('#filterStatus').on('change', applyFilter);

            $('#adminScanQrBtn').on('click', function(){ $('#adminQrScanModal').modal('show'); });
            $('#adminQrScanModal').on('shown.bs.modal', function(){ loadAttendanceData(); setTimeout(startAdminQr, 500); });
            $('#adminQrScanModal').on('hidden.bs.modal', function(){ if(adminQrScanner) adminQrScanner.stop().catch(function(){}); });

            $('#adminMarkPresentBtn').on('click', function(){ adminMarkScanned('Present'); });
            $('#adminMarkLateBtn').on('click', function(){ adminMarkScanned('Late'); });
            $('#adminMarkAbsentBtn').on('click', function(){ adminMarkScanned('Absent'); });

            $(document).on('click', '.att-mark', function() {
                var eid=$(this).data('eid'), attId=$(this).data('attid'), status=$(this).data('status');
                if (!eid) { showToast('No enrollment record for this entry.','warning'); return; }
                var date = currentDate;
                if (attId) {
                    $.ajax({ type:'PUT', url:'/AttendanceManagement/Attendance/'+attId, contentType:'application/json', data:JSON.stringify({ attendance_ID:parseInt(attId), enrollment_ID:parseInt(eid), status:status, date:date+'T00:00:00Z', lastUpdatedBy:'admin' }),
                        success:function(){ loadAttendanceData(); }, error:function(x){ showToast('Update failed: '+(x.responseJSON&&x.responseJSON.message||'error'),'error'); } });
                } else {
                    $.ajax({ type:'POST', url:'/AttendanceManagement/Attendance', contentType:'application/json', data:JSON.stringify({ enrollment_ID:parseInt(eid), status:status, date:date+'T00:00:00Z', lastUpdatedBy:'admin' }),
                        success:function(){ loadAttendanceData(); }, error:function(x){ showToast('Mark failed: '+(x.responseJSON&&x.responseJSON.message||'error'),'error'); } });
                }
            });
        });
    </script>
}