@{
    Layout = "_Layout";
    ViewData["Title"] = "Manage Courses";
}
<div class="page-header">
    <div>
        <h4><i class="bi bi-journal-bookmark-fill"></i> Courses</h4>
        <ol class="breadcrumb"><li class="breadcrumb-item"><a href="/Admin/Dashboard">Home</a></li><li class="breadcrumb-item active">Courses</li></ol>
    </div>
    <button class="btn btn-primary" id="openAddCourse"><i class="bi bi-plus-circle"></i> Add Course</button>
</div>

<div class="card">
    <div class="card-header flex-wrap gap-2">
        <div class="card-header-title"><i class="bi bi-list-ul"></i> Course List</div>
        <div class="d-flex flex-wrap gap-2 ms-auto">
            <div class="search-bar">
                <i class="bi bi-search"></i>
                <input type="text" class="form-control" id="searchCourse" placeholder="Search courses...">
            </div>
        </div>
    </div>
    <div class="table-wrapper">
        <table class="table table-striped">
            <thead>
                <tr><th>ID</th><th>Code</th><th>Title</th><th>Description</th><th>Assigned Teacher</th><th>Actions</th></tr>
            </thead>
            <tbody id="courseTableBody"></tbody>
        </table>
    </div>
    <div class="pagination-wrapper"><div id="coursePagination"></div></div>
</div>

<div class="modal fade" id="courseModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-plus-circle"></i> Add Course</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="courseId">
                <div class="mb-3">
                    <label class="form-label">Course Code <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="courseCode" placeholder="e.g. CS101">
                </div>
                <div class="mb-3">
                    <label class="form-label">Course Title <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="courseTitle" placeholder="e.g. Introduction to Programming">
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" id="courseDesc" rows="3" placeholder="Optional course description"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Assign Teacher <span class="text-danger">*</span></label>
                    <select class="form-select" id="courseTeacher"></select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveCourseBtn"><i class="bi bi-check-lg"></i> Save Course</button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="editCourseModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil"></i> Edit Course</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editCourseId">
                <div class="mb-3">
                    <label class="form-label">Course Code <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="editCourseCode">
                </div>
                <div class="mb-3">
                    <label class="form-label">Course Title <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="editCourseTitle">
                </div>
                <div class="mb-3">
                    <label class="form-label">Description</label>
                    <textarea class="form-control" id="editCourseDesc" rows="3"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label">Assign Teacher</label>
                    <select class="form-select" id="editCourseTeacher">
                        <option value="">Unassigned</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="updateCourseBtn"><i class="bi bi-check-lg"></i> Update Course</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var allCourses = [], allTeachers = [], allUsers = [], coursePaginator;

        function parseDocId(series) {
            if (!series) return '';
            var p = String(series).split('-');
            var n = parseInt(p[p.length - 1], 10);
            return isNaN(n) ? '' : String(n);
        }

        function loadTeacherDropdown() {
            $.when(
                $.getJSON('/api/proxy/api/Teacher'),
                $.getJSON('/api/proxy/api/User')
            ).done(function(tR, uR) {
                allTeachers = Array.isArray(tR[0]) ? tR[0] : [];
                allUsers = Array.isArray(uR[0]) ? uR[0] : [];
                var html = '<option value="">Select teacher</option>';
                allTeachers.forEach(function(teacher) {
                    var userDoc = teacher.userDocumentSeries || teacher.UserDocumentSeries;
                    var user = allUsers.find(function(x) {
                        return String(x.documentSeries || x.DocumentSeries) === String(userDoc);
                    });
                    var name = user ? user.full_Name : (teacher.documentSeries || 'Teacher');
                    var tid = parseDocId(teacher.documentSeries || teacher.DocumentSeries);
                    if (tid) html += '<option value="' + tid + '">' + name + '</option>';
                });
                $('#editCourseTeacher, #courseTeacher').html(html);
            });
        }

        function renderCourseRow(c, idx) {
            var cid = c.course_ID || c.id;
            var code = c.code || '—';
            var title = c.title || '—';
            var desc = c.description || '—';
            var teacherId = c.teacher_ID;
            var tds = c.teacherDocumentSeries || c.TeacherDocumentSeries;
            var teacher = allTeachers.find(function(t) {
                return String(t.teacher_ID || t.id) === String(teacherId) ||
                    String(t.documentSeries || t.DocumentSeries) === String(tds);
            });
            var teacherUser = teacher ? allUsers.find(function(u) { return String(u.user_ID) === String(teacher.user_ID); }) : null;
            var teacherName = teacherUser ? teacherUser.full_Name : (teacherId ? 'Assigned' : 'Unassigned');
            var init = (title[0] || 'C').toUpperCase();
            return '<tr>' +
                '<td>' + cid + '</td>' +
                '<td><span style="background:#DBEAFE;color:var(--accent);padding:4px 10px;border-radius:6px;font-size:12px;font-weight:600;">' + code + '</span></td>' +
                '<td><div class="d-flex align-items-center gap-2"><div style="width:28px;height:28px;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;">' + init + '</div>' + title + '</div></td>' +
                '<td style="max-width:200px;overflow:hidden;text-overflow:ellipsis;">' + desc + '</td>' +
                '<td>' + teacherName + '</td>' +
                '<td><button class="btn btn-sm btn-outline-primary btn-icon edit-course" data-id="' + cid + '" title="Edit"><i class="bi bi-pencil"></i></button></td>' +
                '</tr>';
        }

        function loadCourses() {
            $('#page-loader').fadeIn(150);
            console.log("Loading courses...");

            $.ajax({
                url: '/AttendanceManagement/Course',
                dataType: 'json',
                success: function(c) {
                    console.log("Courses loaded:", c);
                    allCourses = Array.isArray(c) ? c : [];
                    if (coursePaginator) {
                        coursePaginator.refresh(allCourses);
                    } else {
                        coursePaginator = paginate({
                            data: allCourses, pageSize: 15,
                            containerId: 'courseTableBody', paginationId: 'coursePagination',
                            colSpan: 6, emptyMsg: 'No courses found.',
                            renderRow: renderCourseRow
                        });
                    }
                    $('#page-loader').fadeOut(200);
                },
                error: function(xhr, status, error) {
                    $('#page-loader').fadeOut(200);
                    console.error("AJAX Error:", status, error);
                    console.error("Response:", xhr.responseText);
                    showToast('Failed to load courses. Check console for details.', 'error');
                }
            });
        }

        $(function() {
            loadTeacherDropdown();
            loadCourses();

            $('#searchCourse').on('input', function() {
                var q = $(this).val().toLowerCase();
                var filtered = allCourses.filter(function(c) {
                    return (c.code || '').toLowerCase().includes(q) ||
                           (c.title || '').toLowerCase().includes(q);
                });
                coursePaginator.refresh(filtered);
            });

            $('#openAddCourse').click(function() {
                $('#courseModalTitle').html('<i class="bi bi-plus-circle"></i> Add Course');
                $('#courseId, #courseCode, #courseTitle, #courseDesc').val('');
                $('#courseModal').modal('show');
            });

            $('#saveCourseBtn').click(function() {
                var code = $('#courseCode').val().trim();
                var title = $('#courseTitle').val().trim();
                var desc = $('#courseDesc').val().trim();

                if (!code) { showToast('Course code is required.', 'warning'); return; }
                if (!title) { showToast('Course title is required.', 'warning'); return; }

                var teacherId = $('#courseTeacher').val();
                if (!teacherId) { showToast('Please assign a teacher.', 'warning'); return; }
                var data = { code: code, title: title, description: desc || null, teacher_ID: parseInt(teacherId, 10) };
                $.ajax({
                    type: 'POST', url: '/AttendanceManagement/Course',
                    contentType: 'application/json', data: JSON.stringify(data),
                    beforeSend: function() { $('#page-loader').fadeIn(150); },
                    success: function() {
                        $('#page-loader').fadeOut(200);
                        $('#courseModal').modal('hide');
                        loadCourses();
                        showToast('Course added successfully.', 'success');
                    },
                    error: function(x) {
                        $('#page-loader').fadeOut(200);
                        showToast('Add failed: ' + (x.responseJSON && x.responseJSON.message || 'error'), 'error');
                    }
                });
            });

            $(document).on('click', '.edit-course', function() {
                var cid = $(this).data('id');
                var course = allCourses.find(function(c) { return String(c.course_ID || c.id) === String(cid); });
                if (course) {
                    $('#editCourseId').val(cid);
                    $('#editCourseCode').val(course.code || '');
                    $('#editCourseTitle').val(course.title || '');
                    $('#editCourseDesc').val(course.description || '');
                    var tds = course.teacherDocumentSeries || course.TeacherDocumentSeries;
                    var tOpt = allTeachers.find(function(t) { return String(t.documentSeries || t.DocumentSeries) === String(tds); });
                    $('#editCourseTeacher').val(tOpt ? parseDocId(tOpt.documentSeries || tOpt.DocumentSeries) : (course.teacher_ID || ''));
                    $('#editCourseModal').modal('show');
                }
            });

            $('#updateCourseBtn').click(function() {
                var cid = $('#editCourseId').val();
                var code = $('#editCourseCode').val().trim();
                var title = $('#editCourseTitle').val().trim();
                var desc = $('#editCourseDesc').val().trim();
                var teacherId = $('#editCourseTeacher').val();

                if (!code) { showToast('Course code is required.', 'warning'); return; }
                if (!title) { showToast('Course title is required.', 'warning'); return; }

                if (!teacherId) { showToast('Please assign a teacher.', 'warning'); return; }
                var data = {
                    code: code, title: title, description: desc || null,
                    teacher_ID: parseInt(teacherId, 10)
                };
                $.ajax({
                    type: 'PUT', url: '/AttendanceManagement/Course/' + cid,
                    contentType: 'application/json', data: JSON.stringify(data),
                    beforeSend: function() { $('#page-loader').fadeIn(150); },
                    success: function() {
                        $('#page-loader').fadeOut(200);
                        $('#editCourseModal').modal('hide');
                        loadCourses();
                        showToast('Course updated successfully.', 'success');
                    },
                    error: function(x) {
                        $('#page-loader').fadeOut(200);
                        showToast('Update failed: ' + (x.responseJSON && x.responseJSON.message || 'error'), 'error');
                    }
                });
            });
        });
    </script>
}