@{
    Layout = null;
    ViewData["Title"] = "Page Not Found";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 - Don Bosco AMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="error-wrap">
        <div class="error-card">
            <div class="notfound-art">4<span>0</span>4</div>
            <div class="error-title">Page not found</div>
            <div class="error-desc">The page you are looking for doesn't exist or has been moved.</div>
            <div class="nav-links">
                <a href="/" class="nav-link-card"><i class="bi bi-house-door"></i> Home</a>
                <a href="javascript:history.back()" class="nav-link-card"><i class="bi bi-arrow-left"></i> Go Back</a>
            </div>
        </div>
    </div>
</body>
</html>