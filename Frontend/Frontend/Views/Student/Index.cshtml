@{
    Layout = "_Layout";
    ViewData["Title"] = "Students";
}
<div class="page-header">
    <div>
        <h4><i class="bi bi-people"></i> Students</h4>
        <ol class="breadcrumb"><li class="breadcrumb-item active">Students</li></ol>
    </div>
</div>
<div class="card">
    <div class="card-header">
        <div class="card-header-title"><i class="bi bi-people-fill"></i> Student List</div>
        <div class="search-bar">
            <i class="bi bi-search"></i>
            <input type="text" class="form-control" id="sSearch" placeholder="Search...">
        </div>
    </div>
    <div class="table-wrapper">
        <table class="table table-striped">
            <thead>
                <tr><th>#</th><th>Name</th><th>Email</th><th>Gender</th><th>Year Level</th><th>Actions</th></tr>
            </thead>
            <tbody id="sBody"></tbody>
        </table>
    </div>
    <div class="pagination-wrapper"><div id="sPagination"></div></div>
</div>

<div class="modal fade" id="editStudentModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil"></i> Edit Student</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editUserId">
                <input type="hidden" id="editStudentId">
                <input type="hidden" id="editUserGroupId">
                <h6 class="text-muted mb-3"><i class="bi bi-person-fill"></i> User Account</h6>
                <div class="row g-2">
                    <div class="col-md-6"><label class="form-label">Full Name</label><input type="text" class="form-control" id="editFullName"></div>
                    <div class="col-md-6"><label class="form-label">Email</label><input type="email" class="form-control" id="editEmail"></div>
                    <div class="col-md-6"><label class="form-label">Phone</label><input type="text" class="form-control" id="editPhone"></div>
                    <div class="col-md-3">
                        <label class="form-label">Gender</label>
                        <select class="form-select" id="editGender"><option value="M">Male</option><option value="F">Female</option></select>
                    </div>
                    <div class="col-md-3"><label class="form-label">Birth Date</label><input type="date" class="form-control" id="editBirthDate"></div>
                    <div class="col-md-6"><label class="form-label">Address</label><input type="text" class="form-control" id="editAddress"></div>
                </div>
                <hr>
                <h6 class="text-muted mb-3"><i class="bi bi-mortarboard"></i> Student Info</h6>
                <div class="row g-2">
                    <div class="col-md-4">
                        <label class="form-label">Program</label>
                        <select class="form-select" id="editProgramId"><option value="">Loading...</option></select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Department</label>
                        <select class="form-select" id="editDeptId"><option value="">Loading...</option></select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Year Level</label>
                        <select class="form-select" id="editYearLevel">
                            <option value="1st Year">1st Year</option>
                            <option value="2nd Year">2nd Year</option>
                            <option value="3rd Year">3rd Year</option>
                            <option value="4th Year">4th Year</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" id="updateStudentBtn"><i class="bi bi-check-lg"></i> Update</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var STUDENT_GROUP_ID = 3;
        var sStudents = [], sUsers = [], sPrograms = [], sPg;

        function toUtcIso(dateVal) {
            if (!dateVal) return new Date().toISOString();
            return new Date(dateVal).toISOString();
        }

        function getStudentUserId(s) {
            return s.user_ID || s.userId || s.User_ID || null;
        }

        function getStudentRecordId(s) {
            return s.student_ID || s.studentId || s.Student_ID || s.id || null;
        }

        function findUserForStudent(s) {
            var uid = getStudentUserId(s);
            if (!uid) return {};
            return sUsers.find(function(u) {
                return String(u.user_ID) === String(uid) ||
                       String(u.userId)  === String(uid);
            }) || {};
        }

        function renderSRow(s, i) {
            var user  = findUserForStudent(s);
            var sid   = getStudentRecordId(s);
            var uid   = getStudentUserId(s);
            var ugid  = user.userGroup_ID || STUDENT_GROUP_ID;

            var name   = s.full_Name || s.fullName || user.full_Name || user.fullName || '—';
            var email  = s.email || user.email || '—';
            var gender = (s.gender || user.gender);
            var genderLabel = gender === 'M' ? 'Male' : gender === 'F' ? 'Female' : (gender || '—');
            var year   = s.year_Level || s.yearLevel || '—';

            return '<tr>' +
                '<td>' + (i+1) + '</td>' +
                '<td><div class="d-flex align-items-center gap-2">' +
                '<div style="width:30px;height:30px;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:11px;">' + (name[0]||'?').toUpperCase() + '</div>' +
                name + '</div></td>' +
                '<td>' + email + '</td>' +
                '<td>' + genderLabel + '</td>' +
                '<td>' + year + '</td>' +
                '<td class="d-flex gap-1">' +
                '<button class="btn btn-sm btn-outline-primary btn-icon s-edit-btn" data-sid="' + sid + '" data-uid="' + uid + '" data-ugid="' + ugid + '" title="Edit"><i class="bi bi-pencil"></i></button>' +
                '<button class="btn btn-sm btn-outline-danger btn-icon s-del-btn" data-sid="' + sid + '" data-uid="' + uid + '" data-name="' + name + '" title="Delete"><i class="bi bi-trash3"></i></button>' +
                '</td></tr>';
        }

        function loadSDropdowns(progSelId, deptSelId, selProgId, selDeptId) {
            getPrograms(function(p) {
                sPrograms = p;
                var o = '<option value="">Select Program</option>';
                p.forEach(function(x) {
                    var n = x.name || x.program_Name || 'Program ' + x.id;
                    o += '<option value="' + x.id + '" ' + (x.id == selProgId ? 'selected' : '') + '>' + n + '</option>';
                });
                $(progSelId).html(o);
            });
            getDepartments(function(d) {
                var o = '<option value="">Select Department</option>';
                d.forEach(function(x) {
                    var n = x.name || x.department_Name || 'Dept ' + x.id;
                    o += '<option value="' + x.id + '" ' + (x.id == selDeptId ? 'selected' : '') + '>' + n + '</option>';
                });
                $(deptSelId).html(o);
            });
        }

        function loadSStudents() {
            $.when(
                $.ajax({ url: '/api/Student', dataType: 'json' }),
                $.ajax({ url: '/api/User',    dataType: 'json' })
            ).done(function(sRes, uRes) {
                sStudents = Array.isArray(sRes[0]) ? sRes[0] : [];
                sUsers    = Array.isArray(uRes[0]) ? uRes[0] : [];

                if (sStudents.length > 0) console.log('Student fields:', JSON.stringify(sStudents[0]));
                if (sUsers.length > 0)    console.log('User fields:',    JSON.stringify(sUsers[0]));

                if (sPg) sPg.refresh(sStudents);
                else sPg = paginate({
                    data: sStudents, pageSize: 10,
                    containerId: 'sBody', paginationId: 'sPagination',
                    colSpan: 6, emptyMsg: 'No students found.',
                    renderRow: renderSRow
                });
            }).fail(function() { showToast('Failed to load students.', 'error'); });
        }

        $(function () {
            loadSStudents();

            $('#sSearch').on('input', function () {
                var q = $(this).val().toLowerCase();
                sPg.refresh(sStudents.filter(function(s) {
                    var user = findUserForStudent(s);
                    var name  = s.full_Name || s.fullName || user.full_Name || '';
                    var email = s.email || user.email || '';
                    return name.toLowerCase().includes(q) || email.toLowerCase().includes(q);
                }));
            });

            $(document).on('click', '.s-edit-btn', function () {
                var sid  = $(this).data('sid');
                var uid  = $(this).data('uid');
                var ugid = $(this).data('ugid') || STUDENT_GROUP_ID;

                var s = sStudents.find(function(x){
                    return String(getStudentRecordId(x)) === String(sid);
                }) || {};

                var u = sUsers.find(function(x){
                    return String(x.user_ID) === String(uid) ||
                           String(x.userId)  === String(uid);
                }) || {};

                // Pre-fill all fields with existing data
                var name   = s.full_Name || s.fullName || u.full_Name || u.fullName || '';
                var email  = s.email || u.email || '';
                var phone  = s.phone_Number || s.phoneNumber || u.phone_Number || u.phoneNumber || '';
                var gender = s.gender || u.gender || 'M';
                var bdate  = (s.birth_Date || s.birthDate || u.birth_Date || u.birthDate || '').substring(0,10);
                var addr   = s.address || s.Address || u.address || u.Address || '';
                var year   = s.year_Level || s.yearLevel || '1st Year';

                $('#editStudentId').val(sid);
                $('#editUserId').val(uid);
                $('#editUserGroupId').val(ugid);
                $('#editFullName').val(name);
                $('#editEmail').val(email);
                $('#editPhone').val(phone);
                $('#editGender').val(gender);
                $('#editBirthDate').val(bdate);
                $('#editAddress').val(addr);
                $('#editYearLevel').val(year);
                loadSDropdowns('#editProgramId', '#editDeptId', s.program_ID || s.programId, s.department_ID || s.departmentId);
                $('#editStudentModal').modal('show');
            });

            $('#updateStudentBtn').on('click', function () {
                var uid  = $('#editUserId').val();
                var sid  = $('#editStudentId').val();
                var ugid = parseInt($('#editUserGroupId').val()) || STUDENT_GROUP_ID;
                if (!$('#editFullName').val().trim()) { showToast('Full name is required.', 'warning'); return; }
                var userData = {
                    user_ID:      parseInt(uid),
                    full_Name:    $('#editFullName').val().trim(),
                    email:        $('#editEmail').val().trim(),
                    password:     'unchanged',
                    phone_Number: $('#editPhone').val().trim(),
                    gender:       $('#editGender').val(),
                    birth_Date:   toUtcIso($('#editBirthDate').val()),
                    address:      $('#editAddress').val().trim(),
                    userGroup_ID: ugid,
                    lastUpdatedBy: 'admin'
                };
                var studentData = {
                    program_ID:    parseInt($('#editProgramId').val()) || 0,
                    department_ID: parseInt($('#editDeptId').val()) || 0,
                    year_Level:    $('#editYearLevel').val(),
                    lastUpdatedBy: 'admin'
                };
                updateStudent(uid, userData, sid, studentData, function () {
                    $('#editStudentModal').modal('hide');
                    loadSStudents();
                });
            });

            $(document).on('click', '.s-del-btn', function () {
                var sid  = $(this).data('sid');
                var uid  = $(this).data('uid');
                var name = $(this).data('name');
                confirmDelete(name, function () { deleteStudent(uid, sid, loadSStudents); });
            });
        });
    </script>
}