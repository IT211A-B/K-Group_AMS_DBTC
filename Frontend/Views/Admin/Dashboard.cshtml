@{
    Layout = "_Layout";
    ViewData["Title"] = "Admin Dashboard";
}
<div class="page-header">
    <div>
        <h4><i class="bi bi-speedometer2"></i> Dashboard</h4>
        <ol class="breadcrumb"><li class="breadcrumb-item active">Dashboard</li></ol>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addAccountModal">
        <i class="bi bi-person-plus"></i> Enroll New Account
    </button>
</div>

<div class="row g-4 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="bi bi-people"></i></div>
            <div><div class="stat-label">Total Students</div><div class="stat-value" id="statStudents">—</div></div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon green"><i class="bi bi-person-badge"></i></div>
            <div><div class="stat-label">Total Teachers</div><div class="stat-value" id="statTeachers">—</div></div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon orange"><i class="bi bi-journal-bookmark-fill"></i></div>
            <div><div class="stat-label">Total Courses</div><div class="stat-value" id="statCourses">—</div></div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon red"><i class="bi bi-calendar-x"></i></div>
            <div><div class="stat-label">Absences Today</div><div class="stat-value" id="statAbsences">—</div></div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header flex-wrap gap-2">
        <div class="card-header-title"><i class="bi bi-table"></i> Population List</div>
        <div class="d-flex flex-wrap gap-2 ms-auto align-items-center">
            <select class="form-select form-select-sm" id="filterRole" style="width:130px;">
                <option value="">All Roles</option>
                <option value="teacher">Teachers</option>
                <option value="student">Students</option>
            </select>
            <select class="form-select form-select-sm" id="sortBy" style="width:140px;">
                <option value="">Sort by…</option>
                <option value="name-asc">Name A→Z</option>
                <option value="name-desc">Name Z→A</option>
            </select>
            <div class="search-bar">
                <i class="bi bi-search"></i>
                <input type="text" class="form-control" id="searchStudent" placeholder="Search name or email…">
            </div>
        </div>
    </div>
    <div class="table-wrapper">
        <table class="table table-striped">
            <thead>
                <tr><th>#</th><th>Name</th><th>Email</th><th>Role</th><th>Gender</th><th>Program / Dept</th><th>Courses</th><th>Actions</th></tr>
            </thead>
            <tbody id="studentTableBody"></tbody>
        </table>
    </div>
    <div class="pagination-wrapper"><div id="studentPagination"></div></div>
</div>

<!-- Add Account Modal -->
<div class="modal fade" id="addAccountModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-plus"></i> Enroll New Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label fw-semibold">Account Type</label>
                    <div class="btn-group w-100" role="group">
                        <input type="radio" class="btn-check" name="acctType" id="typeStudent" value="student" checked>
                        <label class="btn btn-outline-primary" for="typeStudent"><i class="bi bi-mortarboard"></i> Student</label>
                        <input type="radio" class="btn-check" name="acctType" id="typeTeacher" value="teacher">
                        <label class="btn btn-outline-primary" for="typeTeacher"><i class="bi bi-person-badge"></i> Teacher</label>
                    </div>
                </div>
                <hr>
                <h6 class="text-muted mb-3"><i class="bi bi-person-fill"></i> User Account</h6>
                <div class="row g-2">
                    <div class="col-md-6"><label class="form-label">Full Name <span class="text-danger">*</span></label><input type="text" class="form-control" id="addFullName"></div>
                    <div class="col-md-6">
                        <label class="form-label">Email <span class="text-danger">*</span></label>
                        <input type="email" class="form-control" id="addEmail" placeholder="user@domain.dbtc-cebu">
                        <div style="font-size:11px;color:#94A3B8;margin-top:2px;" id="addEmailHint"></div>
                    </div>
                    <div class="col-md-6"><label class="form-label">Password <span class="text-danger">*</span></label><input type="password" class="form-control" id="addPassword"></div>
                    <div class="col-md-6"><label class="form-label">Phone</label><input type="text" class="form-control" id="addPhone"></div>
                    <div class="col-md-4"><label class="form-label">Gender</label><select class="form-select" id="addGender"><option value="M">Male</option><option value="F">Female</option></select></div>
                    <div class="col-md-4"><label class="form-label">Birth Date</label><input type="date" class="form-control" id="addBirthDate"></div>
                    <div class="col-md-4"><label class="form-label">Address</label><input type="text" class="form-control" id="addAddress"></div>
                </div>
                <hr>
                <div id="studentFields">
                    <h6 class="text-muted mb-3"><i class="bi bi-mortarboard"></i> Student Info</h6>
                    <div class="row g-2">
                        <div class="col-md-4"><label class="form-label">Program</label><select class="form-select" id="addProgramId"></select></div>
                        <div class="col-md-4"><label class="form-label">Department</label><select class="form-select" id="addDeptId"></select></div>
                        <div class="col-md-4"><label class="form-label">Year Level</label><select class="form-select" id="addYearLevel"><option value="1st Year">1st Year</option><option value="2nd Year">2nd Year</option><option value="3rd Year">3rd Year</option><option value="4th Year">4th Year</option></select></div>
                        <div class="col-md-12"><label class="form-label">Enroll in Course(s)</label><div id="addStudentCourses" style="max-height:120px;overflow-y:auto;border:1px solid #e2e8f0;border-radius:6px;padding:8px;"></div></div>
                    </div>
                </div>
                <div id="teacherFields" style="display:none;">
                    <h6 class="text-muted mb-3"><i class="bi bi-briefcase"></i> Teacher Info</h6>
                    <div class="row g-2">
                        <div class="col-md-12"><label class="form-label">Department</label><input type="text" class="form-control" id="addTeacherDept"></div>
                        <div class="col-md-12"><label class="form-label">Assign Course(s)</label><div id="addTeacherCourses" style="max-height:120px;overflow-y:auto;border:1px solid #e2e8f0;border-radius:6px;padding:8px;"></div></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" id="saveAccountBtn">Save Account</button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Modal -->
<div class="modal fade" id="editStudentModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil"></i> Edit Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editUserId">
                <input type="hidden" id="editStudentId">
                <input type="hidden" id="editTeacherId">
                <input type="hidden" id="editUserGroupId">
                <h6 class="text-muted mb-3">User Account</h6>
                <div class="row g-2">
                    <div class="col-md-6"><label class="form-label">Full Name</label><input type="text" class="form-control" id="editFullName"></div>
                    <div class="col-md-6"><label class="form-label">Email</label><input type="email" class="form-control" id="editEmail"></div>
                    <div class="col-md-6"><label class="form-label">Phone</label><input type="text" class="form-control" id="editPhone"></div>
                    <div class="col-md-3"><label class="form-label">Gender</label><select class="form-select" id="editGender"><option value="M">Male</option><option value="F">Female</option></select></div>
                    <div class="col-md-3"><label class="form-label">Birth Date</label><input type="date" class="form-control" id="editBirthDate"></div>
                    <div class="col-md-6"><label class="form-label">Address</label><input type="text" class="form-control" id="editAddress"></div>
                </div>
                <hr>
                <div id="editStudentSection">
                    <h6 class="text-muted mb-3">Student Info</h6>
                    <div class="row g-2">
                        <div class="col-md-4"><label class="form-label">Program</label><select class="form-select" id="editProgramId"></select></div>
                        <div class="col-md-4"><label class="form-label">Department</label><select class="form-select" id="editDeptId"></select></div>
                        <div class="col-md-4"><label class="form-label">Year Level</label><select class="form-select" id="editYearLevel"><option value="1st Year">1st Year</option><option value="2nd Year">2nd Year</option><option value="3rd Year">3rd Year</option><option value="4th Year">4th Year</option></select></div>
                    </div>
                </div>
                <div id="editTeacherSection" style="display:none;">
                    <h6 class="text-muted mb-3">Teacher Info</h6>
                    <div class="row g-2">
                        <div class="col-md-12"><label class="form-label">Department</label><input type="text" class="form-control" id="editTeacherDept"></div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary" id="updateStudentBtn">Update</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/ajax/dashboard.js"></script>
    <script src="~/js/admin-dashboard.js"></script>
    <script>
        $(function() {
            // Force refresh of dashboard stats and accounts
            getDashboardStats();
            loadAll();
        });
    </script>
}