@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Login";
}
<div class="login-page">
    <div class="login-card">
        <div class="login-form-panel">
            <div class="text-center mb-4">
                <img src="~/favicon.ico" alt="Logo" style="width:100px;height:100px;object-fit:contain;margin-bottom:14px;display:block;margin-left:auto;margin-right:auto;" />
                <div style="font-size:20px;font-weight:800;color:var(--primary);line-height:1.25;">DON BOSCO TECHNICAL COLLEGE CEBU</div>
                <div style="font-size:14px;color:var(--accent);font-weight:600;margin-top:6px;">Attendance Management</div>
            </div>

            <div class="role-tabs" id="roleTabs">
                <div class="role-tab active" data-role="admin">Admin</div>
                <div class="role-tab" data-role="teacher">Teacher</div>
                <div class="role-tab" data-role="student">Student</div>
            </div>
            <input type="hidden" id="selectedRole" value="admin" />

            <div class="alert alert-info py-2 mb-2" id="emailHint" style="font-size:12px;">
                <i class="bi bi-info-circle"></i> Admin accounts must end with <strong>.admin</strong>
            </div>
            <div class="alert alert-danger d-none py-2" id="loginError" style="font-size:12px;"></div>

            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" class="form-control" id="loginEmail" placeholder="user@domain.admin" autocomplete="username" />
            </div>
            <div class="mb-1">
                <label class="form-label">Password</label>
                <div class="input-icon-wrap">
                    <input type="password" class="form-control" id="loginPassword" placeholder="Enter your password" autocomplete="current-password" />
                    <i class="bi bi-eye-slash" id="togglePwd" style="position:absolute;right:12px;top:50%;transform:translateY(-50%);cursor:pointer;color:#94A3B8;font-size:16px;z-index:10;"></i>
                </div>
            </div>
            <div class="text-end mb-3">
                <a href="#" style="font-size:11.5px;color:var(--text-muted);font-style:italic;">Forgot Password?</a>
            </div>
            <button type="button" class="btn-login" id="loginBtn">
                <span id="loginBtnText">Login</span>
                <span id="loginBtnSpinner" class="spinner-border spinner-border-sm d-none" role="status"></span>
            </button>
        </div>
        <div class="login-img-panel">
            <img src="~/Background.jpg" alt="Campus" />
            <div style="position:absolute;inset:0;background:linear-gradient(160deg,rgba(26,58,143,.65) 0%,rgba(37,99,235,.40) 100%);"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var roleDomains = { admin: '.admin', teacher: '.local', student: '.dbtc-cebu' };
        var roleHints   = { admin: 'Admin accounts must end with <strong>.admin</strong>', teacher: 'Teacher accounts must end with <strong>.local</strong>', student: 'Student accounts must end with <strong>.dbtc-cebu</strong>' };

        document.getElementById('togglePwd').addEventListener('click', function () {
            var i = document.getElementById('loginPassword');
            i.type = i.type === 'password' ? 'text' : 'password';
            this.className = i.type === 'text' ? 'bi bi-eye' : 'bi bi-eye-slash';
            this.style.cssText = 'position:absolute;right:12px;top:50%;transform:translateY(-50%);cursor:pointer;color:#94A3B8;font-size:16px;z-index:10;';
        });

        document.querySelectorAll('.role-tab').forEach(function (tab) {
            tab.addEventListener('click', function () {
                document.querySelectorAll('.role-tab').forEach(function (t) { t.classList.remove('active'); });
                this.classList.add('active');
                var role = this.getAttribute('data-role');
                document.getElementById('selectedRole').value = role;
                document.getElementById('emailHint').innerHTML = '<i class="bi bi-info-circle"></i> ' + roleHints[role];
                var ph = { admin: 'user@domain.admin', teacher: 'user@domain.local', student: 'user@domain.dbtc-cebu' };
                document.getElementById('loginEmail').placeholder = ph[role];
                document.getElementById('loginError').classList.add('d-none');
            });
        });

        function doLogin() {
            var email = document.getElementById('loginEmail').value.trim();
            var pwd   = document.getElementById('loginPassword').value.trim();
            var role  = document.getElementById('selectedRole').value;
            var errEl = document.getElementById('loginError');
            errEl.classList.add('d-none');

            if (!email || !pwd) { errEl.textContent = 'Email and password are required.'; errEl.classList.remove('d-none'); return; }

            var requiredDomain = roleDomains[role];
            if (!email.endsWith(requiredDomain)) {
                errEl.textContent = 'Invalid email for ' + role + '. Email must end with "' + requiredDomain + '".';
                errEl.classList.remove('d-none');
                return;
            }

            document.getElementById('loginBtnText').textContent = 'Signing in...';
            document.getElementById('loginBtnSpinner').classList.remove('d-none');
            document.getElementById('loginBtn').disabled = true;

            fetch('/Login/Authenticate', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ email, password: pwd, role })
            })
            .then(res => res.json().then(data => ({ ok: res.ok, data })))
            .then(({ ok, data }) => {
                if (ok) {
                    if (data.role === 'teacher') window.location.href = '/Teacher/Dashboard';
                    else if (data.role === 'student') window.location.href = '/Student/Profile';
                    else window.location.href = '/Admin/Dashboard';
                } else {
                    errEl.textContent = data.message || 'Invalid email or password.';
                    errEl.classList.remove('d-none');
                    document.getElementById('loginBtnText').textContent = 'Login';
                    document.getElementById('loginBtnSpinner').classList.add('d-none');
                    document.getElementById('loginBtn').disabled = false;
                }
            })
            .catch(() => {
                errEl.textContent = 'Connection error. Please try again.';
                errEl.classList.remove('d-none');
                document.getElementById('loginBtnText').textContent = 'Login';
                document.getElementById('loginBtnSpinner').classList.add('d-none');
                document.getElementById('loginBtn').disabled = false;
            });
        }

        document.getElementById('loginBtn').addEventListener('click', doLogin);
        document.getElementById('loginPassword').addEventListener('keydown', function (e) { if (e.key === 'Enter') doLogin(); });
    </script>
}