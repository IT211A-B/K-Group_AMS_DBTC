@{
    Layout = "_Layout";
    ViewData["Title"] = "Student Profile";
    var isAdminView = ViewData["IsAdminView"] as bool? ?? false;
    var targetUserId = ViewData["TargetUserId"]?.ToString() ?? "";
    var sessionUserId = Context.Session.GetString("UserId") ?? "";
    var resolvedUserId = isAdminView && !string.IsNullOrEmpty(targetUserId) ? targetUserId : sessionUserId;
}

<input type="hidden" id="targetUserId" value="@resolvedUserId" />
<input type="hidden" id="isAdminView" value="@(isAdminView ? "1" : "0")" />

<div class="page-header">
    <div>
        <h4><i class="bi bi-person-circle"></i> @(isAdminView ? "Student Profile (Admin View)" : "My Profile")</h4>
        <ol class="breadcrumb">
            @if (isAdminView)
            {
                <li class="breadcrumb-item"><a href="/Admin/Dashboard">Dashboard</a></li>
            }
            <li class="breadcrumb-item active">Profile</li>
        </ol>
    </div>
    @if (isAdminView)
    {
        <a href="/Admin/Dashboard" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back</a>
    }
</div>

<div class="row g-3">
    <div class="col-md-5">
        <div class="card">
            <div class="profile-header">
                <div class="profile-avatar" id="profileInitial">S</div>
                <div>
                    <div class="profile-name" id="profileName">Loading...</div>
                    <div class="profile-role" id="profileRole">Student</div>
                </div>
            </div>
            <div class="card-body">
                <div class="info-row"><i class="bi bi-envelope-fill"></i> <strong>Email:</strong> <span id="profileEmail">—</span></div>
                <div class="info-row"><i class="bi bi-telephone-fill"></i> <strong>Phone:</strong> <span id="profilePhone">—</span></div>
                <div class="info-row"><i class="bi bi-geo-alt-fill"></i> <strong>Address:</strong> <span id="profileAddress">—</span></div>
                <div class="info-row"><i class="bi bi-gender-ambiguous"></i> <strong>Gender:</strong> <span id="profileGender">—</span></div>
                <div class="info-row"><i class="bi bi-calendar-fill"></i> <strong>Birth Date:</strong> <span id="profileBirth">—</span></div>
                <div class="info-row"><i class="bi bi-mortarboard-fill"></i> <strong>Program:</strong> <span id="profileProgram">—</span></div>
                <div class="info-row"><i class="bi bi-building"></i> <strong>Department:</strong> <span id="profileDept">—</span></div>
                <div class="info-row"><i class="bi bi-layers-fill"></i> <strong>Year Level:</strong> <span id="profileYear">—</span></div>
                <div class="info-row"><i class="bi bi-person-badge-fill"></i> <strong>Student ID:</strong> <span id="profileStudentId">—</span></div>
                <div class="info-row"><i class="bi bi-clock-fill"></i> <strong>Member Since:</strong> <span id="profileJoined">—</span></div>
                <hr />
                @if (!isAdminView)
                {
                    <a href="/Login/Logout" class="btn btn-outline-danger w-100"><i class="bi bi-box-arrow-right"></i> Logout</a>
                }
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card mb-3">
            <div class="card-header"><div class="card-header-title"><i class="bi bi-bar-chart"></i> Attendance Summary</div></div>
            <div class="card-body">
                <div class="row text-center g-3">
                    <div class="col-4"><div style="background:#DCFCE7;border-radius:10px;padding:16px;"><div class="attend-big-num num-present" id="sumPresent">—</div><small>Present</small></div></div>
                    <div class="col-4"><div style="background:#FEE2E2;border-radius:10px;padding:16px;"><div class="attend-big-num num-absent" id="sumAbsent">—</div><small>Absent</small></div></div>
                    <div class="col-4"><div style="background:#FEF3C7;border-radius:10px;padding:16px;"><div class="attend-big-num num-late" id="sumLate">—</div><small>Late</small></div></div>
                </div>
            </div>
        </div>
        <div class="card">
            <div class="card-header"><div class="card-header-title"><i class="bi bi-calendar3"></i> Attendance Calendar</div></div>
            <div class="card-body"><div id="miniCalendar"></div></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var userId = document.getElementById('targetUserId').value;
        var isAdmin = document.getElementById('isAdminView').value === '1';

        function loadStudentProfile() {
            if (!userId) return;
            $.when(
                $.ajax({ url: '/api/User/' + userId, dataType: 'json' }),
                $.ajax({ url: '/api/Student', dataType: 'json' }),
                $.ajax({ url: '/AttendanceManagement/Program', dataType: 'json' }),
                $.ajax({ url: '/AttendanceManagement/Department', dataType: 'json' })
            ).done(function(uRes, sRes, pRes, dRes) {
                var user = uRes[0] || {};
                var students = Array.isArray(sRes[0]) ? sRes[0] : [];
                var programs = Array.isArray(pRes[0]) ? pRes[0] : [];
                var depts = Array.isArray(dRes[0]) ? dRes[0] : [];

                var student = students.find(function(s) { return String(s.user_ID) === String(userId); }) || {};

                $('#profileName').text(user.full_Name || '—');
                $('#profileInitial').text((user.full_Name || 'S')[0].toUpperCase());
                $('#profileEmail').text(user.email || '—');
                $('#profilePhone').text(user.phone_Number || '—');
                $('#profileAddress').text(user.address || '—');
                $('#profileGender').text(user.gender === 'M' ? 'Male' : user.gender === 'F' ? 'Female' : (user.gender || '—'));
                $('#profileBirth').text(user.birth_Date ? new Date(user.birth_Date).toLocaleDateString() : '—');
                $('#profileStudentId').text(student.student_ID || student.id || '—');
                $('#profileJoined').text(user.createdAt ? new Date(user.createdAt).toLocaleDateString() : '—');
                $('#profileYear').text(student.year_Level || '—');

                var program = programs.find(function(p) { return String(p.program_Id) === String(student.program_ID); });
                $('#profileProgram').text(program ? (program.name || '—') : (student.program_ID ? 'Program #' + student.program_ID : '—'));

                var dept = depts.find(function(d) { return String(d.department_Id) === String(student.department_ID); });
                $('#profileDept').text(dept ? (dept.name || '—') : (student.department_ID ? 'Dept #' + student.department_ID : '—'));
            });
        }

        function loadAttendance() {
            $.ajax({ url: '/AttendanceManagement/Enrollment', dataType: 'json',
                success: function(enrollments) {
                    var allEnr = Array.isArray(enrollments) ? enrollments : [];
                    $.ajax({ url: '/api/Student', dataType: 'json',
                        success: function(students) {
                            var allStudents = Array.isArray(students) ? students : [];
                            var student = allStudents.find(function(s) { return String(s.user_ID) === String(userId); });
                            if (!student) return;
                            var myEnrollments = allEnr.filter(function(e) { return String(e.student_ID) === String(student.student_ID); });
                            var eids = myEnrollments.map(function(e) { return e.enrollment_ID; });
                            $.ajax({ url: '/AttendanceManagement/Attendance', dataType: 'json',
                                success: function(attData) {
                                    var allAtt = Array.isArray(attData) ? attData : [];
                                    var myAtt = allAtt.filter(function(a) { return eids.includes(a.enrollment_ID); });
                                    $('#sumPresent').text(myAtt.filter(a => (a.status || '').toLowerCase() === 'present').length);
                                    $('#sumAbsent').text(myAtt.filter(a => (a.status || '').toLowerCase() === 'absent').length);
                                    $('#sumLate').text(myAtt.filter(a => (a.status || '').toLowerCase() === 'late').length);
                                    var records = {};
                                    myAtt.forEach(function(a) { var d = (a.date || '').substring(0, 10); if (d) records[d] = (a.status || '').toLowerCase(); });
                                    if (typeof renderMiniCalendar === 'function')
                                        renderMiniCalendar('miniCalendar', new Date().getFullYear(), new Date().getMonth(), records);
                                }
                            });
                        }
                    });
                }
            });
        }

        $(function() { loadStudentProfile(); loadAttendance(); });
    </script>
}